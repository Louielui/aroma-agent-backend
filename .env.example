# Copy this file to .env and fill in as needed.  (.env is gitignored — never commit keys)

# LLM provider:  mock = no key needed (see it work first) | claude = real understanding
LLM_PROVIDER=mock

# Only required when LLM_PROVIDER=claude.  Read from env ONLY, never committed.
ANTHROPIC_API_KEY=

# Optional
CLAUDE_MODEL=claude-3-5-haiku-20241022
PORT=8081
# AROMA_DATA_DIR=./data
